<div class="flex items-center justify-center md:bg-base-200">
  <div class="w-full max-w-md bg-white shadow-lg rounded-lg p-8 md:my-20">
    <h2 class="text-2xl font-bold text-center mb-6">新規会員登録</h2>
    <%= form_with model: @user, url: signup_path, local: true, data: { turbo: false }  do |f| %>
      <div class="form-control mb-4">
        <%= f.label :nickname, class: "label" %>
        <%= f.text_field :nickname, autofocus: true, autocomplete: "nickname", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control mb-4">
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control mb-4">
        <%= f.label :password, class: "label" %>
        <%= f.password_field :password, class: "input input-bordered w-full" %>
      </div>

      <div class="form-control mb-6">
        <%= f.label :password_confirmation, class: "label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control">
        <%= f.submit '登録', class: "btn btn-primary w-full" %>
      </div>
    <% end %>

    <p class="mt-10 text-center text-sm/6 text-gray-500">
      <%= link_to 'ログインはこちら', login_path, class: 'font-semibold text-indigo-600 hover:text-indigo-500' %>
    </p>
  </div>
</div>
