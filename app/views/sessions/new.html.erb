<div class="flex items-center justify-center md:bg-base-200">
  <div class="w-full max-w-md bg-white shadow-lg rounded-lg p-8 md:my-20">
    <h2 class="text-2xl font-bold text-center mb-6">ログイン</h2>
    <%= form_with url: login_path, scope: :session, local: true, data: { turbo: false }  do |f| %>
      <div class="form-control mb-4">
        <%= f.label :email, t('sessions.new.email'), class: "label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control mb-4">
        <%= f.label :password, t('sessions.new.password'), class: "label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control">
        <%= f.submit "ログイン", class: "btn btn-primary w-full" %>
      </div>
    <% end %>

    <p class='mt-10 text-center text-sm/6 text-gray-500'>
      <%= link_to '会員登録はこちら', signup_path, class: 'font-semibold text-indigo-600 hover:text-indigo-500' %>
    </p>
  </div>
</div>
